# Copy this file to .env and replace the placeholder values.

# Required for --data-source live SEC EDGAR requests.
# SEC asks automated clients to identify app/contact information.
SEC_USER_AGENT="ai-infra-review your-email@example.com"

# Optional market data. If unset, market data falls back to mock/missing fields.
MARKET_DATA_PROVIDER="mock"
MARKET_DATA_API_KEY=""
